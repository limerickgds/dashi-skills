# Skill evaluation workspaces
*-workspace/

# Packaged skill files (generated artifacts, not source)
*.skill

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# macOS thumbnails
._*

# macOS directories
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# macOS files that might appear in the root of a volume
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.cache/

# Node modules (if any skills use npm)
node_modules/

# Python cache (if any skills use Python)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/

# Environment files
.env
.env.local
.env.*.local
